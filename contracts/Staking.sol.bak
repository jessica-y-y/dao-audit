// SPDX-License-Identifier: MIT
pragma solidity ^0.8.25;

import "@openzeppelin/contracts/utils/ReentrancyGuard.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/token/ERC20/utils/SafeERC20.sol";
import "@openzeppelin/contracts/token/ERC20/IERC20.sol";

// Interface do oráculo Chainlink
import "@chainlink/contracts/src/v0.8/shared/interfaces/AggregatorV3Interface.sol";

interface IMembership {
    function hasNFT(address user) external view returns (bool);
}

contract Staking is ReentrancyGuard, Ownable {
    using SafeERC20 for IERC20;

    IERC20 public immutable token;
    IMembership public immutable membership;

    // Oráculo Chainlink ETH/USD
    AggregatorV3Interface public immutable priceFeed;

    // Preço de referência: $2000 com 8 casas decimais (padrão Chainlink)
    // Abaixo de $2000 → recompensa maior
    // Acima de $2000 → recompensa menor
    uint256 public constant REFERENCE_PRICE = 2000 * 1e8;

    mapping(address => uint256) public staked;
    mapping(address => uint256) public lastUpdate;
    mapping(address => uint256) public rewards;

    uint256 public rewardRate = 1e16; // taxa base

    event Staked(address indexed user, uint256 amount);
    event Unstaked(address indexed user, uint256 amount);
    event RewardClaimed(address indexed user, uint256 reward);
    event RewardRateUpdated(uint256 newRewardRate);

    constructor(
        address token_,
        address membership_,
        address priceFeed_   // endereço do oráculo Chainlink
    ) Ownable(msg.sender) {
        require(token_ != address(0), "Invalid token");
        require(membership_ != address(0), "Invalid membership");
        require(priceFeed_ != address(0), "Invalid price feed");

        token = IERC20(token_);
        membership = IMembership(membership_);
        priceFeed = AggregatorV3Interface(priceFeed_);
    }

    // Consulta o preço atual do ETH/USD no Chainlink
    // Retorna o preco com 8 casas decimais (ex: 200000000000 = $2000.00)
    function getEthUsdPrice() public view returns (uint256) {
        (
            , // roundId — não precisamos
            int256 answer, // preço atual
            , // startedAt — não precisamos
            , // updatedAt — não precisamos
              // answeredInRound — não precisamos
        ) = priceFeed.latestRoundData();

        // Garante que o preço é positivo antes de converter
        require(answer > 0, "Invalid price from oracle");
        return uint256(answer);
    }

    // Calcula o multiplicador de recompensa baseado no preco do ETH
    // Retorna valor em base 1e18 para evitar decimais em Solidity
    // Exemplo: ETH a $1000 (metade do ref) → multiplicador 2x
    //          ETH a $4000 (dobro do ref)  → multiplicador 0.5x
    function getRewardMultiplier() public view returns (uint256) {
        uint256 currentPrice = getEthUsdPrice();

        // Multiplica por 1e18 para manter precisão na divisão inteira
        // Formula: multiplicador = REFERENCE_PRICE / currentPrice
        // ETH $1000: 2000/1000 = 2x ✓
        // ETH $2000: 2000/2000 = 1x ✓
        // ETH $4000: 2000/4000 = 0.5x ✓
        return (REFERENCE_PRICE * 1e18) / currentPrice;
    }

    function stake(uint256 amount) external nonReentrant {
        require(amount > 0, "Amount must be > 0");
        _updateReward(msg.sender);
        token.safeTransferFrom(msg.sender, address(this), amount);
        staked[msg.sender] += amount;
        emit Staked(msg.sender, amount);
    }

    function unstake(uint256 amount) external nonReentrant {
        require(amount > 0, "Amount must be > 0");
        require(staked[msg.sender] >= amount, "Not enough staked");
        _updateReward(msg.sender);
        staked[msg.sender] -= amount;
        token.safeTransfer(msg.sender, amount);
        emit Unstaked(msg.sender, amount);
    }

    function claimReward() external nonReentrant {
        _updateReward(msg.sender);
        uint256 reward = rewards[msg.sender];
        require(reward > 0, "No reward");
        rewards[msg.sender] = 0;
        token.safeTransfer(msg.sender, reward);
        emit RewardClaimed(msg.sender, reward);
    }

    function _updateReward(address user) internal {
        uint256 last = lastUpdate[user];

        if (last == 0) {
            lastUpdate[user] = block.timestamp;
            return;
        }

        uint256 timeDiff = block.timestamp - last;

        if (staked[user] > 0) {
            // Recompensa base sem oráculo
            uint256 baseReward = staked[user] * timeDiff * rewardRate;

            // Aplica o multiplicador do oráculo Chainlink
            // multiplier está em base 1e18, então dividimos por 1e18 no final
            uint256 multiplier = getRewardMultiplier();
            baseReward = (baseReward * multiplier) / 1e18;

            // Bonus por NFT (mantido do contrato original)
            if (membership.hasNFT(user)) {
                baseReward *= 2;
            }

            baseReward = baseReward / 1e18;
            rewards[user] += baseReward;
        }

        lastUpdate[user] = block.timestamp;
    }

    function setRewardRate(uint256 newRewardRate) external onlyOwner {
        require(newRewardRate > 0, "Invalid rate");
        rewardRate = newRewardRate;
        emit RewardRateUpdated(newRewardRate);
    }
}